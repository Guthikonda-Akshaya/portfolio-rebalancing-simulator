{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Streamlit App",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/app.py",
                "--server.port",
                "8501",
                "--browser.gatherUsageStats",
                "false"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
